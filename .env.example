# ===========================================
# EducatorWeb — Docker 部署环境变量模板
# ===========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys
# 3. .env is gitignored — never commit secrets!

# ======== 必需配置 ========

# DeepSeek API Key（AI 对话/内容生成）
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ======== 可选配置 ========

# Exa AI 语义搜索 API Key（不填也可用免费额度 100次/月）
# 获取: https://exa.ai
EXA_API_KEY=

# MySQL root 密码（默认 root，修改后需同步改 docker-compose.yml）
MYSQL_ROOT_PASSWORD=root

# Neo4j 密码（默认 password）
NEO4J_PASSWORD=password

# DeepSeek API 地址（默认官方地址）
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 豆包/Seedance 视频生成 API Key（可选，不填则无法生成视频）
SEEDANCE_API_KEY=

# ======== 扩展服务（可选） ========

# 讯飞星火（比赛要求可用）
XUNFEI_API_KEY=
XUNFEI_API_SECRET=
XUNFEI_APP_ID=

# OpenAI
OPENAI_API_KEY=

# 硅基流动
SILICONFLOW_API_KEY=
