# ===========================================
# EducatorWeb — Environment Variables Template
# ===========================================
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual API keys and passwords
# 3. .env is gitignored — never commit secrets!

# --- LLM Providers (at least one required) ---

# DeepSeek API Key (prototype development)
# Get yours at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Xunfei Spark API (competition requirement)
# Get yours at: https://console.xfyun.cn/
XUNFEI_API_KEY=your-xunfei-api-key
XUNFEI_API_SECRET=your-xunfei-api-secret
XUNFEI_APP_ID=your-xunfei-app-id

# --- Databases ---

# MySQL root password (default: root)
MYSQL_PASSWORD=root

# Neo4j password (default: password)
NEO4J_PASSWORD=password

# Redis password (leave empty if no password set)
REDIS_PASSWORD=

# Qdrant vector database (for RAG)
QDRANT_HOST=localhost
QDRANT_API_KEY=

# --- External Services ---

# mem0 API key (student profile memory)
# Get yours at: https://app.mem0.ai/
MEM0_API_KEY=
